{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2023"],
    "types": ["node", "jest"],

    "paths": {
      "@/*": ["./src/*"]
    },

    "module": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,

    "isolatedModules": true
  }
}